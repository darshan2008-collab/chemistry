# TrueNAS dataset root (required)
PROJECT_ROOT=c:/Users/harri/Desktop/Git/chemistry

# Public host port for the web app
APP_PORT=10004

# App/runtime settings
APP_ENV=production
TZ=Asia/Kolkata
API_PORT=3000
RETENTION_DAYS=90
# Daily at 02:30
CLEANUP_SCHEDULE=30 2 * * *

# PostgreSQL settings (used by chemtest-db + chemtest-api)
DB_HOST=chemtest-db
DB_PORT=5432
DB_NAME=chemistry
DB_USER=chemistry_user
DB_PASSWORD=change_me
RESYNC_TOKEN=change_this_token

# On first startup, student master data is seeded automatically
# from ${PROJECT_ROOT}/students-db.js into the database.

# Upload files are persisted at:
# ${PROJECT_ROOT}/data/uploads

# Docker network name used by this stack
STACK_NETWORK=chemistry-stack-net
