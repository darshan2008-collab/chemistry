# Persistent uploads/data root (required)
UPLOADS_ROOT=/mnt/Hdd/Hdd/Hari/Projects/Chemistry/data/uploads
POSTGRES_ROOT=/mnt/Hdd/Hdd/Hari/Projects/Chemistry/data/postgres

# Public host port for the web app
APP_PORT=10004

# App/runtime settings
APP_ENV=production
TZ=Asia/Kolkata
API_PORT=3000
RETENTION_DAYS=90
# Daily at 02:30
CLEANUP_SCHEDULE=30 2 * * *

# PostgreSQL settings (used by chemtest-db + chemtest-api)
DB_HOST=chemtest-db
DB_PORT=5432
DB_NAME=chemistry
DB_USER=chemistry_user
DB_PASSWORD=ChemistryDB_2026!R8n4
RESYNC_TOKEN=chem_resync_2026_9f4a3d17ab
AUTH_PEPPER=chem_authpepper_2026_c1a79e42f0
AUTH_SESSION_TTL_HOURS=24

# Default staff account seed (first startup only)
STAFF_DEFAULT_EMAIL=admin@chemtest.in
STAFF_DEFAULT_PASSWORD=Admin@2026!Chem
STAFF_DEFAULT_NAME=Dr. Admin
STAFF_DEFAULT_ROLE=Chemistry Teacher

# On first startup, student master data is seeded automatically
# from students-db.js into the database.

# Upload files are persisted at:
# ${UPLOADS_ROOT}

# Docker network name used by this stack
STACK_NETWORK=chemistry-stack-net
