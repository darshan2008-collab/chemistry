# TrueNAS dataset root (required)
PROJECT_ROOT=/mnt/Hdd/Hdd/Hari/Projects/Chemistry

# Public host port for the web app
APP_PORT=10004

# App/runtime settings
APP_ENV=production
TZ=Asia/Kolkata
API_PORT=3000
RETENTION_DAYS=90
# Daily at 02:30
CLEANUP_SCHEDULE=30 2 * * *

# PostgreSQL settings (used by chemtest-db + chemtest-api)
# For internal DB container use: DB_HOST=chemtest-db
# For external DB use host/IP, for example: DB_HOST=192.168.1.36
DB_HOST=__SET_DB_HOST__
DB_PORT=5432
DB_NAME=__SET_DB_NAME__
DB_USER=__SET_DB_USER__
DB_PASSWORD=__SET_DB_PASSWORD__
RESYNC_TOKEN=__SET_LONG_RANDOM_TOKEN__

# On first startup, student master data is seeded automatically
# from ${PROJECT_ROOT}/students-db.js into the database.

# Upload files are persisted at:
# ${PROJECT_ROOT}/data/uploads

# Docker network name used by this stack
STACK_NETWORK=chemistry-stack-net
