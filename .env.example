# Persistent uploads storage path on host (required)
# Example TrueNAS path: /mnt/tank/apps/chemistry-data/uploads
UPLOADS_ROOT=/mnt/Hdd/Hdd/Hari/Projects/Chemistry/data/uploads
POSTGRES_ROOT=/mnt/Hdd/Hdd/Hari/Projects/Chemistry/data/postgres

# Public host port for the web app
APP_PORT=10004

# App/runtime settings
APP_ENV=production
TZ=Asia/Kolkata
API_PORT=3000
RETENTION_DAYS=90
# Daily at 02:30
CLEANUP_SCHEDULE=30 2 * * *
# Auto-upsert students from students-db.js on every API startup
STUDENTS_SYNC_ON_STARTUP=true
# Auto-assign all students to default CHEMISTRY subject on startup
BASELINE_ASSIGNMENTS_ON_STARTUP=false
# Auto-assign all students to UHV subject on startup
UHV_ASSIGNMENTS_ON_STARTUP=false

# PostgreSQL settings (used by chemtest-api)
# External DB recommended for production.
# To use bundled DB container, set DB_HOST=chemtest-db and run with profile internal-db.
DB_HOST=__SET_DB_HOST__
DB_PORT=5432
DB_NAME=__SET_DB_NAME__
DB_USER=__SET_DB_USER__
DB_PASSWORD=__SET_DB_PASSWORD__
RESYNC_TOKEN=__SET_LONG_RANDOM_TOKEN__
AUTH_PEPPER=__SET_LONG_RANDOM_AUTH_PEPPER__
AUTH_SESSION_TTL_HOURS=24
PASSWORD_HASH_ROUNDS=12

# Default staff account (inserted/updated on API startup)
STAFF_DEFAULT_EMAIL=__SET_STAFF_USERNAME__
STAFF_DEFAULT_PASSWORD=__SET_STAFF_PASSWORD__
STAFF_DEFAULT_NAME=__SET_STAFF_NAME__
STAFF_DEFAULT_ROLE=Chemistry Teacher

# Default super admin account (inserted/updated on API startup)
SUPERADMIN_DEFAULT_EMAIL=__SET_SUPERADMIN_USERNAME__
SUPERADMIN_DEFAULT_PASSWORD=__SET_SUPERADMIN_PASSWORD__
SUPERADMIN_DEFAULT_NAME=__SET_SUPERADMIN_NAME__
SUPERADMIN_DEFAULT_ROLE=Super Admin

# UHV staff account (inserted/updated on API startup)
UHV_STAFF_EMAIL=__SET_UHV_USERNAME__
UHV_STAFF_PASSWORD=__SET_UHV_PASSWORD__
UHV_STAFF_NAME=__SET_UHV_NAME__
UHV_STAFF_ROLE=UHV Teacher

# On first startup, student master data is seeded automatically
# from students-db.js included in the API image.
# With STUDENTS_SYNC_ON_STARTUP=true, this sync runs on every API startup.

# Upload files are persisted at:
# ${UPLOADS_ROOT}

# Docker network name used by this stack
STACK_NETWORK=chemistry-stack-net
