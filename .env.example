# TrueNAS dataset root (required)
PROJECT_ROOT=/mnt/Hdd/Hdd/Hari/Projects/Chemistry

# Public host port for the web app
APP_PORT=10004

# App/runtime settings
APP_ENV=production
TZ=Asia/Kolkata

# External PostgreSQL database (no DB container in this stack)
DB_HOST=your-postgres-host-or-ip
DB_PORT=5432
DB_NAME=chemistry
DB_USER=chemistry_user
DB_PASSWORD=change_me
DB_SSLMODE=require

# Docker network name used by this stack
STACK_NETWORK=chemistry-stack-net
